    "pinata": "^2.5.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
